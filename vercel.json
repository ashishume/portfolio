{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/ssr.js": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/open/:path*",
      "destination": "/open.html"
    },
    { "source": "/(.*)", "destination": "/api/ssr" }
  ]
}
